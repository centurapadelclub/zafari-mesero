# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# Firebase (iOS): mantener fuera del repo si se agrega en el futuro.
# NOTA: google-services.json (Android) SÍ se commitea y NO debe ignorarse:
# EAS excluye del build los archivos gitignoreados aunque estén committeados,
# y @react-native-firebase/app lo necesita en el build (android.googleServicesFile).
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
