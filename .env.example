# Copia este archivo a `.env` y completa con las credenciales del proyecto
# Supabase del sistema web (Project Settings -> API en el dashboard de Supabase).
#
# El prefijo EXPO_PUBLIC_ es OBLIGATORIO: solo así Expo expone la variable al
# código del cliente (process.env.EXPO_PUBLIC_...).
#
# La ANON KEY es pública por diseño (se protege con Row Level Security en la BD),
# por eso es seguro incluirla en una app cliente. NUNCA pongas aquí la service_role key.

EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...tu-anon-key...

# Opcional: solo si compilas con EAS y usas el push service de Expo en vez de FCM directo.
# EAS_PROJECT_ID=

# Opcional: ruta a google-services.json si no está en la raíz del proyecto.
# GOOGLE_SERVICES_JSON=./google-services.json
